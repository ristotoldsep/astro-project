Options -MultiViews -Indexes
RewriteEngine On
RewriteBase /

# Serve pre-existing files/dirs directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean URLs: /about  →  /about/index.html
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
RewriteRule ^(.+[^/])$ %{REQUEST_URI}/index.html [L]

# 404 fallback
ErrorDocument 404 /404/index.html

# -----------------------------
# Caching + compression
# -----------------------------

<IfModule mod_headers.c>
	# HTML should revalidate so content updates appear quickly
	<FilesMatch "\.(html)$">
		Header set Cache-Control "no-cache, must-revalidate"
	</FilesMatch>

	# Never cache dynamic PHP endpoint
	<FilesMatch "\.(php)$">
		Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
	</FilesMatch>

	# Astro hashed assets can be cached aggressively
	<FilesMatch "^_astro/.+\.(js|mjs|css|woff2?|ttf|otf|svg|png|jpe?g|webp|avif|gif)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>

	# Other static assets
	<FilesMatch "\.(js|mjs|css|woff2?|ttf|otf|svg|png|jpe?g|webp|avif|gif|mp4|webm)$">
		Header set Cache-Control "public, max-age=2592000"
	</FilesMatch>
</IfModule>

<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType text/html "access plus 0 seconds"
	ExpiresByType text/css "access plus 1 month"
	ExpiresByType application/javascript "access plus 1 month"
	ExpiresByType image/avif "access plus 1 month"
	ExpiresByType image/webp "access plus 1 month"
	ExpiresByType image/jpeg "access plus 1 month"
	ExpiresByType image/png "access plus 1 month"
	ExpiresByType image/svg+xml "access plus 1 month"
	ExpiresByType video/mp4 "access plus 1 month"
	ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/plain text/html text/css application/javascript application/json image/svg+xml
</IfModule>
