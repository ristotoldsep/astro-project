---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageBanner from "../components/PageBanner.astro";
import Marquee from "../components/Marquee.astro";
import { Picture } from 'astro:assets';
import portraitAnett from '../assets/images/portrait-anett.avif';
import serviceBiohacking from '../assets/images/service-biohacking.avif';
import { useTranslations, getLocalePath } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const lp = (s: string) => getLocalePath(lang, s);

const pillars = t('about.pillars') as Array<{icon:string;label:string;title:string;text:string}>;

---

<BaseLayout
  title={t('about.metaTitle') as string}
  description={t('about.metaDescription') as string}
  ogImage="/images/portrait-anett.avif"
>
  <PageBanner
    label={t('about.bannerLabel') as string}
    heading={`${t('about.bannerHeading')} <span class="serif-italic">${t('about.bannerHeadingItalic')}</span>`}
    bgImage="/images/hero-alina.avif"
  />

  <Marquee />

  <!-- ══ BIO SPLIT ══ -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__media reveal-left" style="aspect-ratio:3/4;">
          <Picture
            src={portraitAnett}
            alt="Anett Randvee, QiNutritionist — holistic nutritionist and women's wellness expert"
            loading="eager"
            class="h-full"
            widths={[400, 600, 900]}
            sizes="(max-width: 900px) 100vw, 50vw"
            formats={['avif', 'webp']}
          />
          <div class="split__tag" aria-hidden="true">{t('about.bioTag')}</div>
        </div>
        <div class="split__content reveal-right text-center md:text-left">
          <span class="label">{t('about.bioLabel')}</span>
          <h2 style="margin-top:12px;">{t('about.bioH2a')} <span class="serif-italic">{t('about.bioH2b')}</span></h2>
          <p>{t('about.bioP1')}</p>
          <p>{t('about.bioP2')}</p>
          <p>{t('about.bioP3')}</p>
          <a href={lp('/consultation')} class="btn btn-primary" style="margin-top:8px;">{t('about.bioCta')}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ THREE PILLARS ══ -->
  <section class="section section--linen">
    <div class="container">
      <div class="section__header text-center reveal">
        <span class="label">{t('about.pillarsLabel')}</span>
        <h2>{t('about.pillarsH2a')} <span class="serif-italic">{t('about.pillarsH2b')}</span></h2>
      </div>
      <div class="pillars">
        {pillars.map((p, i) => (
          <div class={`pillar reveal delay-${i + 1}`}>
            <span class="pillar__icon" aria-hidden="true">{p.icon}</span>
            <p class="label" style="margin-bottom:16px;">{p.label}</p>
            <h3 class="pillar__title">{p.title}</h3>
            <p class="pillar__text">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ WORK WITH ME SPLIT ══ -->
  <section class="section section--sand">
    <div class="container">
      <div class="split split--reverse">
        <div class="split__content reveal-right text-center md:text-left">
          <span class="label mb-4">{t('about.workLabel')}</span>
          <h2>{t('about.workH2a')} <span class="serif-italic">{t('about.workH2b')}</span></h2>
          <p>{t('about.workP1')}</p>
          <p>{t('about.workP2')}</p>
          <p>{t('about.workP3')}</p>
          <div class="flex flex-wrap gap-3 mt-2 justify-center md:justify-start">
            <a href={lp('/services')} class="btn btn-primary">{t('about.workCta1')}</a>
            <a href={lp('/events')} class="btn btn-outline">{t('about.workCta2')}</a>
          </div>
        </div>
        <div class="split__media reveal-left text-center md:text-left">
          <Picture
            src={serviceBiohacking}
            alt="Holistic wellness practice — herbs and natural supplements"
            loading="lazy"
            class="h-full"
            widths={[400, 600, 900]}
            sizes="(max-width: 900px) 100vw, 50vw"
            formats={['avif', 'webp']}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ══ QUOTE ══ -->
  <section class="section">
    <div class="container">
      <div class="quote-block reveal">
        <div class="quote-block__mark">"</div>
        <p class="quote-block__text">{t('about.quoteText')}</p>
        <p class="quote-block__attr">{t('about.quoteAttr')}</p>
      </div>
    </div>
  </section>

  <!-- ══ PARALLAX CTA ══ -->
  <div class="parallax-band">
    <div class="parallax-band__bg" style="background-image:url('/images/hero-heather.avif');"></div>
    <div class="parallax-band__overlay"></div>
    <div class="parallax-band__content reveal">
      <span class="label" style="color:rgba(253,250,246,.7);">{t('about.parallaxLabel')}</span>
      <h2>{t('about.parallaxH2a')} <span class="serif-italic">{t('about.parallaxH2b')}</span></h2>
      <p style="margin-bottom:28px;opacity:.85;">{t('about.parallaxText')}</p>
      <a href={lp('/consultation')} class="btn btn-white">{t('about.parallaxCta')}</a>
    </div>
  </div>
</BaseLayout>
