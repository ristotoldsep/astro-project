---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Marquee from "../components/Marquee.astro";
import InstaStrip from "../components/InstaStrip.astro";
import "../styles/global.scss";
import { ClientRouter } from "astro:transitions";
import { detectLocale, getLocalePath, useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  /** Path to the OG share image (relative to domain root). Defaults to hero-crystalweed. */
  ogImage?: string;
  /** BCP-47 language tag for this page. Auto-detected from URL if omitted. */
  lang?: Locale;
}

const {
  title,
  description: descriptionProp,
  ogImage = "/images/hero-crystalweed.avif",
  lang: langProp,
} = Astro.props;

const { lang, slug } = detectLocale(Astro.url.pathname);
const effectiveLang: Locale = langProp ?? lang;
const t = useTranslations(effectiveLang);
const description = (descriptionProp ?? t('seo.defaultDescription')) as string;

// hreflang alternate URLs
const siteBase = (Astro.site ?? new URL("https://qinutritionist.com")).href.replace(/\/$/, '');
const lhref = (l: Locale) => { const p = getLocalePath(l, slug); return `${siteBase}${p === '/' ? '' : p}`; };
const hreflangs = [
  { hreflang: 'en',         href: lhref('en') },
  { hreflang: 'et',         href: lhref('et') },
  { hreflang: 'es',         href: lhref('es') },
  { hreflang: 'x-default',  href: lhref('en') },
];

const siteUrl = Astro.site ?? new URL("https://qinutritionist.com");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbsolute = new URL(ogImage, siteUrl).href;
const ogLocaleMap: Record<Locale, string> = { en: 'en_US', et: 'et_EE', es: 'es_ES' };
const ogLocale = ogLocaleMap[effectiveLang];
const personKnowsAbout = t('seo.personKnowsAbout') as string[];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      "url": String(siteUrl),
      "name": "QiNutritionist",
      "description": t('seo.websiteDescription'),
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}#person`,
      "name": "Anett Randvee",
      "jobTitle": t('seo.personJobTitle'),
      "description": t('seo.personDescription'),
      "url": String(siteUrl),
      "sameAs": [
        "https://www.instagram.com/qinutritionist/",
        "https://www.facebook.com/randveeyoga/"
      ],
      "knowsAbout": personKnowsAbout
    }
  ]
});
---

<!doctype html>
<html lang={effectiveLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/qinutritionist_favicon.png" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="QiNutritionist" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="800" />
    <meta property="og:locale" content={ogLocale} />
    <!-- hreflang alternate links -->
    {hreflangs.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />
    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&family=Great+Vibes&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <Nav lang={effectiveLang} />
    <main>
      <slot />
    </main>
    <InstaStrip />
    <Marquee variant="footer" />
    <Footer lang={effectiveLang} />

    <!-- Shared animation bootstrap (GSAP + smooth scrolling + reveal observer) -->
    <script>
      import gsap from "gsap";
      import ScrollTrigger from "gsap/ScrollTrigger";
      import Lenis from "lenis";

      const initRevealObserver = () => {
        const revealEls = document.querySelectorAll(
          ".reveal, .reveal-scale, .reveal-left, .reveal-right",
        );

        if (window.__qiRevealObserver) {
          window.__qiRevealObserver.disconnect();
          window.__qiRevealObserver = null;
        }

        if (!revealEls.length) return;

        const viewportH = window.innerHeight || document.documentElement.clientHeight;

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                io.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.14,
            rootMargin: "0px 0px -6% 0px",
          },
        );

        revealEls.forEach((el) => {
          if (el.classList.contains("visible") || el.classList.contains("reveal-onload")) return;

          const rect = el.getBoundingClientRect();
          const isAboveFold = rect.top < viewportH * 0.92;
          if (isAboveFold) {
            el.classList.add("reveal-onload");
            return;
          }

          io.observe(el);
        });

        window.__qiRevealObserver = io;
      };

      const scheduleRevealInit = () => {
        if (window.__qiRevealRAF) {
          cancelAnimationFrame(window.__qiRevealRAF);
        }
        window.__qiRevealRAF = requestAnimationFrame(() => {
          initRevealObserver();
          window.__qiRevealRAF = null;
        });
      };

      const initPageEnhancements = () => {
        if (window.__qiVideoObserver) {
          window.__qiVideoObserver.disconnect();
          window.__qiVideoObserver = null;
        }

        if (window.__qiCardRadiusOnScroll) {
          window.removeEventListener("scroll", window.__qiCardRadiusOnScroll);
          window.__qiCardRadiusOnScroll = null;
        }

        const storyVideo = document.getElementById("storyVideo");
        if (storyVideo) {
          const vidObs = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) storyVideo.play();
                else storyVideo.pause();
              });
            },
            { threshold: 0.2 },
          );
          vidObs.observe(storyVideo);
          window.__qiVideoObserver = vidObs;
        }

        const cardEls = document.querySelectorAll(".section--card");
        if (cardEls.length) {
          const updateCardRadius = () => {
            const vh = window.innerHeight;
            cardEls.forEach((card) => {
              const rect = card.getBoundingClientRect();
              const progress = Math.min(
                Math.max((vh - rect.top) / (vh * 0.45), 0),
                1,
              );
              card.style.borderRadius = `${(progress * 30).toFixed(1)}px`;
            });
          };

          window.__qiCardRadiusOnScroll = updateCardRadius;
          window.addEventListener("scroll", updateCardRadius, { passive: true });
          updateCardRadius();
        }
      };

      const schedulePageEnhancements = () => {
        if (window.__qiPageEnhanceRAF) {
          cancelAnimationFrame(window.__qiPageEnhanceRAF);
        }
        window.__qiPageEnhanceRAF = requestAnimationFrame(() => {
          initPageEnhancements();
          window.__qiPageEnhanceRAF = null;
        });
      };

      if (!window.__qiAnimationBootstrapDone) {
        window.__qiAnimationBootstrapDone = true;

        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;

        gsap.registerPlugin(ScrollTrigger);

        if (!prefersReducedMotion) {
          const lenis = new Lenis({
            duration: 1.05,
            wheelMultiplier: 0.95,
            touchMultiplier: 0.9,
            smoothWheel: true,
            smoothTouch: false,
          });

          lenis.on("scroll", ScrollTrigger.update);
          gsap.ticker.add((time) => {
            lenis.raf(time * 1000);
          });
          gsap.ticker.lagSmoothing(0);
          window.__qiLenis = lenis;
        }

        document.addEventListener("astro:before-swap", () => {
          // Stop Lenis so it doesn't fight the incoming page scroll reset
          if (window.__qiLenis) window.__qiLenis.stop();
        });

        document.addEventListener("astro:after-swap", () => {
          window.__qiLastLifecyclePath = "";
          // Reset scroll to top — use Lenis if available so it stays in sync
          if (window.__qiLenis) {
            window.__qiLenis.scrollTo(0, { immediate: true });
            window.__qiLenis.start();
          }
          window.scrollTo({ top: 0, left: 0, behavior: "instant" });
        });

        const runPageLifecycle = () => {
          const key = `${window.location.pathname}${window.location.search}`;
          if (window.__qiLastLifecyclePath === key) return;
          window.__qiLastLifecyclePath = key;

          scheduleRevealInit();
          schedulePageEnhancements();
          ScrollTrigger.refresh();
        };

        window.addEventListener("load", runPageLifecycle, { once: true });
        document.addEventListener("astro:page-load", runPageLifecycle);
      }
    </script>
  </body>
</html>
