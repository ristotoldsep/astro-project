---
import { useTranslations, detectLocale } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  variant?: 'footer';
  /** CSS color value to override the strip background, e.g. "white" or "#EDE0D4" or "var(--sand)" */
  bgColor?: string;
  lang?: Locale;
}
const { variant, bgColor, lang: langProp } = Astro.props;
const { lang: urlLang } = detectLocale(Astro.url.pathname);
const lang: Locale = langProp ?? urlLang;
const t = useTranslations(lang);

const items = t('marquee') as string[];
---
<div class:list={['marquee-strip', variant]} style={bgColor ? `--marquee-bg:${bgColor}` : undefined}>
  <div class="marquee-track" aria-hidden="true">
    {[...items, ...items].map((item, i) => (
      <>
        <span class="marquee-item">{item}</span>
        <span class="marquee-sep"></span>
      </>
    ))}
  </div>
</div>
