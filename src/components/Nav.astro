---
import LotusIcon from './LotusIcon.astro';
import { useTranslations, getLocalePath, detectLocale, localeLabels } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  lang?: Locale;
}
const { lang: langProp } = Astro.props;
const { lang: urlLang, slug } = detectLocale(Astro.url.pathname);
const lang: Locale = langProp ?? urlLang;
const t = useTranslations(lang);

const lp = (s: string) => getLocalePath(lang, s);
const isActive = (slug: string) =>
  slug === '/' ? Astro.url.pathname === lp('/') || Astro.url.pathname === `/${lang === 'en' ? '' : lang}` : Astro.url.pathname.startsWith(lp(slug));

const navLinks = [
  { href: '/',             label: t('nav.home') as string },
  { href: '/about',        label: t('nav.about') as string },
  { href: '/events',       label: t('nav.events') as string },
  { href: '/services',     label: t('nav.services') as string },
  { href: '/consultation', label: t('nav.consultation') as string },
];

// Language switcher options — build hrefs pointing to equivalent page in each locale
const langOptions = [
  { code: 'en' as Locale, label: localeLabels.en, href: getLocalePath('en', slug) },
  { code: 'et' as Locale, label: localeLabels.et, href: getLocalePath('et', slug) },
  { code: 'es' as Locale, label: localeLabels.es, href: getLocalePath('es', slug) },
];
---

<header class="site-header" id="siteHeader">
  <!-- Announcement Bar -->
  <div class="announcement-bar">
    {t('nav.announcement')}
  </div>

  <!-- Navigation -->
  <nav class="nav" id="mainNav" aria-label="Main navigation">
    <a href={lp('/')} class="nav__logo" aria-label="QiNutritionist — home">
      <span class="nav__logo-icon">
        <LotusIcon size={30} />
      </span>
      QiNutritionist
    </a>

    <div class="nav__links-wrap" role="none">
      <div class="nav-highlight" id="navHighlight" aria-hidden="true"></div>
      <ul class="nav__links" id="navLinks">
        {navLinks.map(link => (
          <li>
            <a
              href={lp(link.href)}
              class={isActive(link.href) ? 'active' : ''}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
      <!-- Language Switcher -->
      <div class="lang-switch" id="langSwitch">
        <button class="lang-switch__btn" id="langBtn" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language">
          <span id="currentLang">{localeLabels[lang]}</span>
          <svg class="lang-switch__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <ul class="lang-switch__menu" role="listbox" id="langMenu">
          {langOptions.map(opt => (
            <li
              class={`lang-switch__opt${opt.code === lang ? ' active' : ''}`}
              data-lang={opt.label}
              data-href={opt.href}
              role="option"
              aria-selected={opt.code === lang ? 'true' : 'false'}
            >{opt.label}</li>
          ))}
        </ul>
      </div>

      <!-- CTA -->
      <a href={lp('/consultation')} class="btn btn-primary nav__cta">
        {t('nav.bookFreeCall')}
      </a>

      <!-- Burger -->
      <button
        class="nav__burger"
        id="navBurger"
        aria-label={t('nav.toggleMenu') as string}
        aria-expanded="false"
        aria-controls="navMobile"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Menu Backdrop -->
<div class="nav__backdrop" id="navBackdrop" aria-hidden="true"></div>

<!-- Mobile Menu -->
<nav class="nav__mobile" id="navMobile" aria-label="Mobile navigation" aria-hidden="true">
  <div class="nav__mobile-scroll" id="navMobileScroll">
    <ul class="nav__mobile-links">
      {navLinks.map((link, i) => (
        <li style={`--i:${i}`}>
          <a
            href={lp(link.href)}
            class={isActive(link.href) ? 'active' : ''}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav__mobile-lang" aria-label="Language selection">
      {langOptions.map(opt => (
        <a
          href={opt.href}
          class={`nav__mobile-lang-opt${opt.code === lang ? ' active' : ''}`}
          aria-label={`Switch to ${opt.label}`}
        >
          {opt.label}
        </a>
      ))}
    </div>

    <a href={lp('/consultation')} class="btn btn-primary nav__mobile-cta">
      {t('nav.bookFreeCall')}
    </a>
  </div>
</nav>

<script>
  const initNav = () => {
    const header = document.getElementById('siteHeader');
    const nav = document.getElementById('mainNav');
    const burger = document.getElementById('navBurger');
    const mobile = document.getElementById('navMobile');
    const backdrop = document.getElementById('navBackdrop');
    const links = document.getElementById('navLinks');
    const highlight = document.getElementById('navHighlight');
    const langSwitch = document.getElementById('langSwitch');
    const langBtn = document.getElementById('langBtn');
    const langMenu = document.getElementById('langMenu');

    if (!header || !nav || !burger || !mobile || !backdrop || !links || !highlight || !langSwitch || !langBtn || !langMenu) {
      return;
    }

    const setHeaderH = () => {
      document.documentElement.style.setProperty('--header-h', `${header.offsetHeight}px`);
    };
    setHeaderH();

    if (window.__qiHeaderRO) {
      window.__qiHeaderRO.disconnect();
    }
    const ro = new ResizeObserver(setHeaderH);
    ro.observe(header);
    window.__qiHeaderRO = ro;

    if (window.__qiNavOnScroll) {
      window.removeEventListener('scroll', window.__qiNavOnScroll);
    }
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 20);
    window.__qiNavOnScroll = onScroll;
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    const openMenu = () => {
      burger.classList.add('open');
      burger.setAttribute('aria-expanded', 'true');
      mobile.classList.add('open');
      mobile.setAttribute('aria-hidden', 'false');
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
      document.body.style.touchAction = 'none';
    };

    const closeMenu = () => {
      burger.classList.remove('open');
      burger.setAttribute('aria-expanded', 'false');
      mobile.classList.remove('open');
      mobile.setAttribute('aria-hidden', 'true');
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
      document.body.style.touchAction = '';
    };

    burger.onclick = () => {
      if (burger.classList.contains('open')) closeMenu();
      else openMenu();
    };
    backdrop.onclick = closeMenu;

    mobile.querySelectorAll('a').forEach((anchor) => {
      anchor.addEventListener('click', closeMenu, { once: true });
    });

    if (window.__qiNavOnKeydown) {
      document.removeEventListener('keydown', window.__qiNavOnKeydown);
    }
    const onKeyDown = (e) => {
      if (e.key === 'Escape') closeMenu();
    };
    window.__qiNavOnKeydown = onKeyDown;
    document.addEventListener('keydown', onKeyDown);

    const moveHighlight = (el) => {
      const r = el.getBoundingClientRect();
      const lr = links.getBoundingClientRect();
      highlight.style.left = `${r.left - lr.left}px`;
      highlight.style.width = `${r.width}px`;
      highlight.style.opacity = '1';
    };

    links.querySelectorAll('a').forEach((anchor) => {
      anchor.onmouseenter = () => moveHighlight(anchor);
    });
    links.onmouseleave = () => {
      highlight.style.opacity = '0';
    };

    langBtn.onclick = (e) => {
      e.stopPropagation();
      langSwitch.classList.toggle('open');
      langBtn.setAttribute('aria-expanded', String(langSwitch.classList.contains('open')));
    };

    langMenu.querySelectorAll('.lang-switch__opt').forEach((opt) => {
      opt.onclick = () => {
        const href = opt.getAttribute('data-href');
        if (href) window.location.href = href;
      };
    });

    if (window.__qiNavOnDocClick) {
      document.removeEventListener('click', window.__qiNavOnDocClick);
    }
    const onDocClick = () => langSwitch.classList.remove('open');
    window.__qiNavOnDocClick = onDocClick;
    document.addEventListener('click', onDocClick);
  };

  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
