---
import LotusIcon from './LotusIcon.astro';
import { useTranslations, getLocalePath, detectLocale, localeLabels } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  lang?: Locale;
}
const { lang: langProp } = Astro.props;
const { lang: urlLang, slug } = detectLocale(Astro.url.pathname);
const lang: Locale = langProp ?? urlLang;
const t = useTranslations(lang);

const lp = (s: string) => getLocalePath(lang, s);
const isActive = (slug: string) =>
  slug === '/' ? Astro.url.pathname === lp('/') || Astro.url.pathname === `/${lang === 'en' ? '' : lang}` : Astro.url.pathname.startsWith(lp(slug));

const navLinks = [
  { href: '/',             label: t('nav.home') as string },
  { href: '/about',        label: t('nav.about') as string },
  { href: '/events',       label: t('nav.events') as string },
  { href: '/services',     label: t('nav.services') as string },
  { href: '/consultation', label: t('nav.consultation') as string },
];

// Language switcher options — build hrefs pointing to equivalent page in each locale
const langOptions = [
  { code: 'en' as Locale, label: localeLabels.en, href: getLocalePath('en', slug) },
  { code: 'et' as Locale, label: localeLabels.et, href: getLocalePath('et', slug) },
  { code: 'es' as Locale, label: localeLabels.es, href: getLocalePath('es', slug) },
];
---

<!-- Announcement Bar -->
<div class="announcement-bar">
  {t('nav.announcement')}
</div>

<!-- Navigation -->
<nav class="nav" id="mainNav">
  <a href={lp('/')} class="nav__logo">
    <span class="nav__logo-icon">
      <LotusIcon size={30} />
    </span>
    QiNutritionist
  </a>

  <div class="nav__links-wrap">
    <div class="nav-highlight" id="navHighlight"></div>
    <ul class="nav__links" id="navLinks">
      {navLinks.map(link => (
        <li>
          <a href={lp(link.href)} class={isActive(link.href) ? 'active' : ''}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
    <!-- Language Switcher -->
    <div class="lang-switch" id="langSwitch">
      <button class="lang-switch__btn" id="langBtn" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language">
        <span id="currentLang">{localeLabels[lang]}</span>
        <svg class="lang-switch__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <ul class="lang-switch__menu" role="listbox" id="langMenu">
        {langOptions.map(opt => (
          <li
            class={`lang-switch__opt${opt.code === lang ? ' active' : ''}`}
            data-lang={opt.label}
            data-href={opt.href}
            role="option"
            aria-selected={opt.code === lang ? 'true' : 'false'}
          >{opt.label}</li>
        ))}
      </ul>
    </div>

    <!-- CTA -->
    <a href={lp('/consultation')} class="btn btn-primary nav__cta">
      {t('nav.bookFreeCall')}
    </a>

    <!-- Burger -->
    <button class="nav__burger" id="navBurger" aria-label={t('nav.toggleMenu') as string}>
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="nav__mobile" id="navMobile">
  {navLinks.map(link => (
    <a href={lp(link.href)}>{link.label}</a>
  ))}
  <a href={lp('/consultation')} class="btn btn-primary" style="margin-top:16px;">{t('nav.bookFreeCall')}</a>
</div>

<script>
  // Scroll shadow
  const nav = document.getElementById('mainNav')!;
  const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 20);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Burger toggle
  const burger = document.getElementById('navBurger')!;
  const mobile = document.getElementById('navMobile')!;
  burger.addEventListener('click', () => {
    const open = burger.classList.toggle('open');
    mobile.classList.toggle('open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  });

  // Close mobile menu on link click
  mobile.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      burger.classList.remove('open');
      mobile.classList.remove('open');
      document.body.style.overflow = '';
    })
  );

  // Nav highlight pill
  const links = document.getElementById('navLinks')!;
  const highlight = document.getElementById('navHighlight')!;
  const linksRect = () => links.getBoundingClientRect();

  const moveHighlight = (el: HTMLElement) => {
    const r = el.getBoundingClientRect();
    const lr = linksRect();
    highlight.style.left = `${r.left - lr.left}px`;
    highlight.style.width = `${r.width}px`;
    highlight.style.opacity = '1';
  };

  links.querySelectorAll('a').forEach(a => {
    a.addEventListener('mouseenter', () => moveHighlight(a as HTMLElement));
  });
  links.addEventListener('mouseleave', () => {
    highlight.style.opacity = '0';
  });

  // Language switcher
  const langSwitch = document.getElementById('langSwitch')!;
  const langBtn    = document.getElementById('langBtn')!;
  const langMenu   = document.getElementById('langMenu')!;
  const currentLangEl = document.getElementById('currentLang')!;

  langBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    langSwitch.classList.toggle('open');
    langBtn.setAttribute('aria-expanded', String(langSwitch.classList.contains('open')));
  });

  langMenu.querySelectorAll('.lang-switch__opt').forEach(opt => {
    opt.addEventListener('click', () => {
      const href = opt.getAttribute('data-href');
      if (href) window.location.href = href;
    });
  });

  document.addEventListener('click', () => langSwitch.classList.remove('open'));
</script>
