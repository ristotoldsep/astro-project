---
import LotusIcon from "./LotusIcon.astro";
import { useTranslations, getLocalePath, detectLocale } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  lang?: Locale;
}

const { lang: langProp } = Astro.props;
const { lang: urlLang } = detectLocale(Astro.url.pathname);
const lang: Locale = langProp ?? urlLang;
const t = useTranslations(lang);
const lp = (s: string) => getLocalePath(lang, s);

const navLinks = [
  { href: '/',             label: t('nav.home') as string },
  { href: '/about',        label: t('nav.about') as string },
  { href: '/events',       label: t('nav.events') as string },
  { href: '/services',     label: t('nav.services') as string },
  { href: '/consultation', label: t('nav.consultation') as string },
];
const serviceLinks = t('footer.serviceLinks') as string[];
---

<footer class="footer" aria-label={t('footer.footerLabel') as string}>
  <div class="container">
    <div class="footer__grid">
      <!-- ── Brand column ──────────────────────────── -->
      <div>
        <a href={lp('/')} class="footer__logo">
          <span class="footer__logo-icon">
            <LotusIcon size={30} />
          </span>
          QiNutritionist
        </a>
        <p class="footer__tagline">{t('footer.tagline')}</p>
        <ul class="footer__social" aria-label={t('footer.socialLabel') as string}>
          <li>
            <a
              href="https://www.facebook.com/randveeyoga/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={t('footer.facebookLabel') as string}
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                ></path>
              </svg>
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/qinutritionist/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={t('footer.instagramLabel') as string}
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
                focusable="false"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <circle cx="12" cy="12" r="4"></circle>
                <circle
                  cx="17.5"
                  cy="6.5"
                  r="1"
                  fill="currentColor"
                  stroke="none"></circle>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <nav class="footer__col" aria-label={t('footer.navHeading') as string}>
        <h5>{t('footer.navHeading')}</h5>
        <ul>
          {navLinks.map(link => (
            <li>
              <a href={lp(link.href)}>
                <svg class="footer-icon" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true" focusable="false"><path d="M9 18l6-6-6-6"></path></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- ── Services column ───────────────────────── -->
      <div class="footer__col">
        <h5>{t('footer.servicesHeading')}</h5>
        <ul>
          {serviceLinks.map(label => (
            <li>
              <a href={lp('/services')}>
                <svg class="footer-icon" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true" focusable="false"><path d="M9 18l6-6-6-6"></path></svg>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- ── Contact column ────────────────────────── -->
      <address class="footer__col not-italic">
        <h5>{t('footer.contactHeading')}</h5>
        <ul>
          <li>
            <a href="mailto:randveeyoga@gmail.com">
              <svg
                class="footer-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              randveeyoga@gmail.com
            </a>
          </li>
          <li>
            <a href="tel:+37256505371">
              <svg
                class="footer-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 9.5 19.79 19.79 0 0 1 1.61 1a2 2 0 0 1 2-2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 6.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
              +372 56505371
            </a>
          </li>
          <li>
            <span>
              <svg
                class="footer-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Tallinn / Barcelona
            </span>
          </li>
        </ul>
      </address>
    </div>

    <div class="footer__bottom">
      <span>© <span id="footer-year">2026</span> QiNutritionist · Anett 🤍</span>
      <span>{t('footer.bottomRight')}</span>
    </div>
  </div>
</footer>

<script is:inline>
  document.getElementById('footer-year').textContent = new Date().getFullYear();
</script>
